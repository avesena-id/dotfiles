# i3status configuration file (Maximum Minimal Monochrome)
# See "man i3status" for documentation.

general {
        colors = true
        interval = 5
        
        # Mengunci semua warna ke putih/abu-abu terang (Monochrome)
        color_good = "#FFFFFF"
        color_degraded = "#999999"
        color_bad = "#FFFFFF"
}

# Hanya menampilkan modul yang benar-benar esensial
# order += "disk /"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
order += "volume master"
order += "tztime local"

disk "/" {
        format = " DISK %avail "
        prefix_type = "custom"
}

wireless _first_ {
        format_up = " Wlan %quality "
        format_down = "" # Sembunyi jika tidak aktif
}

ethernet _first_ {
        format_up = " Eth %speed "
        format_down = "" # Sembunyi jika tidak aktif
}

battery all {
        # Format super bersih tanpa ikon baterai yang ramai
        format = " BAT %percentage %remaining "
        format_down = ""
        status_chr = "CHR"
        status_bat = "BAT"
        status_unk = "UNK"
        status_full = "FULL"
        path = "/sys/class/power_supply/BAT%d/uevent"
        low_threshold = 10
        threshold_type = "percentage"
}

volume master {
        format = " VOL %volume "
        format_muted = " MUTED "
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}

tztime local {
        # Format waktu 24 jam dan tanggal ultra-clean
        format = " %d-%m-%y %H:%M "
}
